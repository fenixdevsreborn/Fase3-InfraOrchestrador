# ------------------------------------------------------------------------------
# Exemplo de variáveis para FCG Infra Orchestrator
# Copie para terraform.tfvars e ajuste. Não commite terraform.tfvars com segredos.
# ------------------------------------------------------------------------------

environment  = "prod"
project_name = "fcg"
aws_region   = "us-east-1"

# JWT: preencha quando tiver Cognito ou Users API com JWKS
# jwt_issuer_uri = "https://cognito-idp.us-east-1.amazonaws.com/us-east-1_XXXXX"
jwt_issuer_uri = ""
jwt_audience   = ["fcg-cloud-platform"]

# VPC: usar VPC criada pelo módulo (recomendado para demo)
create_vpc = true
vpc_cidr   = "10.0.0.0/16"

# PostgreSQL: senha via variável de ambiente é mais seguro:
# export TF_VAR_postgres_master_password="sua-senha-segura"
postgres_create_db          = true
postgres_allocated_storage_gb = 20
postgres_instance_class     = "db.t3.micro"
postgres_engine_version     = "16"
postgres_master_username    = "fcgadmin"

# Lambda notificação
notification_lambda_memory_mb  = 256
notification_lambda_timeout_sec = 30

# SQS
sqs_notification_queue_name   = "fcg-notification-events"
sqs_message_retention_seconds = 86400

# ECR: sufixos dos repositórios (nome final = project-environment-sufixo)
ecr_repository_names = ["notification-lambda", "games-api", "payments-api", "users-api"]

# Tags de imagem por serviço (atualizadas por workflows de deploy; permite atualizar um serviço por vez)
# Para aplicar só uma: terraform apply -var="ecr_image_tag_notification_lambda=a1b2c3d"
ecr_image_tag_users_api           = "latest"
ecr_image_tag_games_api           = "latest"
ecr_image_tag_payments_api        = "latest"
ecr_image_tag_notification_lambda = "latest"

# Frontend S3
frontend_bucket_name = ""  # vazio = nome gerado automaticamente
frontend_enable_cors = true

# Logs
log_retention_days = 14

# Tags adicionais
tags = {
  Team = "fcg-platform"
}
