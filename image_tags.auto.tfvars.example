# ------------------------------------------------------------------------------
# Tags de imagem por serviço (ECR)
# Copie para image_tags.auto.tfvars (ou use -var-file). Atualizado pelo workflow
# deploy-from-service-update ao receber evento dos repositórios de aplicação.
# ------------------------------------------------------------------------------

ecr_image_tag_users_api              = "latest"
ecr_image_tag_games_api              = "latest"
ecr_image_tag_payments_api           = "latest"
ecr_image_tag_notification_lambda    = "latest"
